{
	"name": "hypejunction/hypedirectory",
	"version": "5.0.0",
	"type": "elgg-plugin",
	"description": "Improved members pages for Elgg",
	"homepage": "https://github.com/hypeJunction/hypeDirectory",
	"keywords": [
		"elgg",
		"plugin",
		"members"
	],
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"composer/installers": "^2.0",
		"elgg/elgg": "^5.0",
		"hypejunction/hypelists": "*"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\Directory\\": "classes/hypeJunction/Directory/"
		}
	},
	"extra": {
		"installer-name": "hypedirectory",
		"elgg-plugin": {
			"id": "hypedirectory"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
